# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/

# OS / editor
.DS_Store
.idea/
.vscode/
*.swp

# Streamlit
.streamlit/secrets.toml

# Large reproducible inputs — regenerate via download_census_pop.py
data/population/tiger/
data/population/usa_pop_2020.tif

# Geofabrik state-wide download + extract — regenerate via download_osm_minneapolis.py
data/osm/minnesota.shp.zip
data/osm/minnesota/

# Geofabrik Texas state-wide download + extract — regenerate via download_osm_sa.py
data/osm/texas.shp.zip
data/osm/texas/

# SA buildings as raw GeoJSON (185 MB, exceeds GitHub's 100 MB hard limit).
# The repo tracks data/sa/buildings_sa.gpkg (92 MB) instead — same content
# in a binary format. Regenerate via download_osm_sa.py if needed.
data/sa/buildings_sa.geojson

# TIGER 2020 source bundles — kept under data/sa/ but the raw zip + extracted
# directory are regenerable; only the city-filtered shapefile is tracked.
data/sa/tracts_bexar/

# Local on-disk cache (osmnx / Streamlit scratch)
cache/

# Minneapolis Full inputs — the runtime-needed files (LULC, soil, pop, tracts,
# roads, buildings.gpkg) ARE tracked. The bulky regenerable source data is not.
# Raw Hennepin SSURGO shapefile (~47 MB) — regenerable via download_ssurgo.py
# + process_ssurgo.py; only soil_group_mpls_full.tif is used at runtime.
data/minneapolis_expanded/ssurgo_hennepin_hsg.*
# SDA tabular dump (regenerable).
data/minneapolis_expanded/ssurgo_hydgrp_hennepin.csv
# Raw TIGER state-wide tract download — only the filtered tracts_hennepin.shp
# (in the parent dir) is tracked.
data/minneapolis_expanded/tracts_hennepin/
# 102 MB raw GeoJSON exceeds GitHub's 100 MB hard limit; tracked file is
# buildings_mpls_full.gpkg (49 MB binary).
data/minneapolis_expanded/buildings_mpls_full.geojson

# CGIAR Global-AI/ET0 v3.1 zip + extracted source TIFF (~865 MB total) —
# regenerate via download_et_sa.py. The clipped data/sa/cooling/et_annual_sa.tif
# (~9 MB) IS tracked since it's the actual model input.
data/sa/cooling/cgiar_et0/

# SA SSURGO source shapefile (~18 MB; regenerate via download_ssurgo_sa.py).
# The rasterized output data/sa/flood/soil_group_sa.tif (~116 KB) IS tracked.
data/sa/flood/ssurgo_bexar_hsg.*
data/sa/flood/ssurgo_hydgrp_bexar.csv
